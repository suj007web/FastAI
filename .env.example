FASTAI_ENV=development
FASTAI_CONFIG_PROFILE=balanced
FASTAI_HOST=0.0.0.0
FASTAI_PORT=8000
FASTAI_LOG_LEVEL=INFO

# Quick start: usually you only change these two lines.
# 1) Which vector backend to use
# 2) Which generation model to use

# Auth
FASTAI_API_AUTH_MODE=disabled

# Vector backend (pgvector | qdrant | mongodb_atlas)
FASTAI_VECTOR_BACKEND=pgvector
FASTAI_VECTOR_DIMENSION=1536
FASTAI_VECTOR_NAMESPACE=default

# Retrieval and context
FASTAI_RETRIEVAL_TOP_K=5
FASTAI_RETRIEVAL_MIN_SCORE=0.0
FASTAI_RETRIEVAL_NUM_CANDIDATES=50
FASTAI_MAX_CONTEXT_TOKENS=3000

# Ingestion defaults
FASTAI_CHUNK_SIZE_TOKENS=500
FASTAI_CHUNK_OVERLAP_TOKENS=50
FASTAI_INGESTION_RECURSIVE=true
FASTAI_INGESTION_MAX_FILES=10000
FASTAI_INGESTION_FAILURE_POLICY=continue
FASTAI_INGESTION_DEDUPE_MODE=checksum_path

# LLM and embedding
FASTAI_LLM_PROVIDER=openai
FASTAI_LLM_MODEL=gpt-4.1-mini
# Embedding model defaults to text-embedding-3-small for quick start.
FASTAI_EMBEDDING_MODEL=text-embedding-3-small
FASTAI_LLM_TIMEOUT_SEC=30
FASTAI_LLM_MAX_RETRIES=2

# Backend connection (pgvector default)
FASTAI_DB_DSN=postgresql+psycopg://fastai:fastai@db:5432/fastai

# Provider credentials (set per provider)
OPENAI_API_KEY=replace_me

# Optional: qdrant backend settings
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=
# QDRANT_COLLECTION=fastai_chunks
# QDRANT_DISTANCE=cosine
# QDRANT_TIMEOUT_SEC=10
# QDRANT_PREFER_GRPC=false

# Optional: mongodb atlas backend settings
# MONGODB_URI=mongodb+srv://...
# MONGODB_DATABASE=fastai
# MONGODB_VECTOR_COLLECTION=chunks
# MONGODB_VECTOR_INDEX_NAME=vector_index
# MONGODB_VECTOR_NUM_CANDIDATES=100
# MONGODB_VECTOR_SIMILARITY=cosine
